# Base URL for the PandaDoc web app.
BASE_URL=https://app.pandadoc.com

# Where auth storage state is written/read.
AUTH_STATE_PATH=auth.json

# Where PandaDoc lands after login (adjust if your tenant uses a different path).
DASHBOARD_URL_PATTERN=**/dashboard**

# Use real Chrome to avoid Google's "This browser or app may not be secure" block.
BROWSER_CHANNEL=chrome
